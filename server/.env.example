# ─── Database ───────────────────────────────────────────────────────────────────
# MongoDB connection string (required)
MONGO_URI=mongodb://127.0.0.1:27017/clinical-system
MONGODB_URI=mongodb://127.0.0.1:27017/clinical-system

# ─── Server ───────────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_ORIGIN=http://localhost:3001

# ─── Authentication ─────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── Speech-to-Text Provider ───��─────────────────────────────────────────────────
# Options: "sarvam" | "mock"
STT_PROVIDER=mock

# Sarvam AI STT (required when STT_PROVIDER=sarvam)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_BASE_URL=https://api.sarvam.ai

# ─── AI Summarization Provider ───────────────────────────────────────────────────
# Options: "proxy" | "mock"
SUMMARIZER_PROVIDER=mock

# AI Proxy endpoint (required when SUMMARIZER_PROVIDER=proxy)
# This should be your OpenAI-compatible or custom LLM endpoint
AI_PROXY_BASE_URL=https://your-proxy-endpoint.com/v1
AI_MODEL=your-model-name
AI_MODEL_ID=your-model-id

# ─── Example: OpenAI ───────────────────────────────────────────────────────────
# SUMMARIZER_PROVIDER=proxy
# AI_PROXY_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o
# AI_MODEL_ID=gpt-4o
# (and set OPENAI_API_KEY in your environment when running)

# ─── Example: Sarvam AI ─────────────────────────────��───────────────────────────
# STT_PROVIDER=sarvam
# SARVAM_API_KEY=your_sarvam_api_key
# SARVAM_BASE_URL=https://api.sarvam.ai